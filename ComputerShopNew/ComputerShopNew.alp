			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>RETURNS_VALUE</ReturnModificator>
					<ReturnType><![CDATA[RectangularNode]]></ReturnType>
					<Id>1778876294635</Id>
					<Name><![CDATA[getRandomPC]]></Name>
					<X>600</X><Y>40</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[ArrayList<Integer> freePCs = new ArrayList<>();

for(int i = 0; i < 29; i++){
    if(pcOccupied[i] == false){
        freePCs.add(i);
    }
}

if(freePCs.isEmpty()){
    return queueArea;
}

int chosen = randomFrom(freePCs);

pcOccupied[chosen] = true;

switch(chosen){
    case 0: return pc1;
    case 1: return pc2;
    case 2: return pc3;
    case 3: return pc4;
    case 4: return pc5;
    case 5: return pc6;
    case 6: return pc7;
    case 7: return pc8;
    case 8: return pc9;
    case 9: return pc10;
    case 10: return pc11;
    case 11: return pc12;
    case 12: return pc13;
    case 13: return pc14;
    case 14: return pc15;
    case 15: return pc16;
    case 16: return pc17;
    case 17: return pc18;
    case 18: return pc19;
    case 19: return pc20;
    case 20: return pc21;
    case 21: return pc22;
    case 22: return pc23;
    case 23: return pc24;
    case 24: return pc25;
    case 25: return pc26;
    case 26: return pc27;
    case 27: return pc28;
    case 28: return pc29;
}

return queueArea;]]></Body>
